generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bookings {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String?   @db.Uuid
  tour_id          String?   @db.Uuid
  booking_date     DateTime? @default(now()) @db.Timestamp(6)
  number_of_people Int
  total_price      Decimal   @db.Decimal(10, 2)
  status           String?   @default("pending")
  tours            tours?    @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments         payments?

  @@index([tour_id], map: "idx_bookings_tour")
  @@index([user_id], map: "idx_bookings_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model destinations {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  country     String
  description String?
  image_url   String?
  tours       tours[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  booking_id          String?   @unique @db.Uuid
  payment_method      String
  amount              Decimal   @db.Decimal(10, 2)
  payment_status      String?   @default("pending")
  payment_date        DateTime? @default(now()) @db.Timestamp(6)
  payos_order_code    BigInt?   @unique
  payos_transaction_id String?
  bookings            bookings? @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model promotions {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                String    @unique
  discount_percentage Int?
  expiration_date     DateTime? @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  tour_id    String?   @db.Uuid
  rating     Int?
  comment    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tours      tours?    @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tour_id], map: "idx_reviews_tour")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tour_images {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tour_id   String? @db.Uuid
  image_url String
  tours     tours?  @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tours {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title          String
  description    String?
  destination_id String?       @db.Uuid
  price          Decimal       @db.Decimal(10, 2)
  duration       Int
  max_capacity   Int
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  bookings       bookings[]
  reviews        reviews[]
  tour_images    tour_images[]
  destinations   destinations? @relation(fields: [destination_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wishlist       wishlist[]

  @@index([destination_id], map: "idx_tours_destination")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  full_name     String
  email         String     @unique
  password_hash String
  role          String?    @default("customer")
  phone_number  String?
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  bookings      bookings[]
  reviews       reviews[]
  wishlist      wishlist[]

  @@index([email], map: "idx_users_email")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model wishlist {
  user_id String @db.Uuid
  tour_id String @db.Uuid
  tours   tours  @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, tour_id])
}
